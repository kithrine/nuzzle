# Neon PostgreSQL connection string
DATABASE_URL=

# RescueGroups v5 API key
RESCUEGROUPS_API_KEY=

# Groq API key (explanation generation only — never used for scoring)
GROQ_API_KEY=

# Clerk keys.
#   Local dev: use development keys (pk_test_ / sk_test_) here.
#   Production: use live keys (pk_live_ / sk_live_) set in the HOST's env vars (e.g. Vercel),
#   not committed. Dev instances send verification emails from a shared accounts.dev sender that
#   often lands in spam / is dropped — real email delivery requires a production instance with your
#   own verified domain (DNS/DKIM) and your own Google/Apple OAuth credentials.
#   See docs/ops/clerk-production-setup.md.

# Clerk backend secret
CLERK_SECRET_KEY=

# Clerk frontend publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk URL routing (custom auth pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/search
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/questionnaire
